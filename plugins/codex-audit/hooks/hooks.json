{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$PLUGIN_ROOT/hooks/tool_audit.sh\" session",
            "timeout": 10,
            "statusMessage": "Codex Audit: logging session start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$PLUGIN_ROOT/hooks/tool_audit.sh\" pre",
            "timeout": 10,
            "statusMessage": "Codex Audit: pre-tool check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$PLUGIN_ROOT/hooks/tool_audit.sh\" post",
            "timeout": 10,
            "statusMessage": "Codex Audit: post-tool log"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$PLUGIN_ROOT/hooks/tool_audit.sh\" prompt",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$PLUGIN_ROOT/hooks/post_turn.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
